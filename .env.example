# Copy this file to .env and fill in your values.
# .env is gitignored — NEVER commit real keys.

# Deployer private key (no 0x prefix) — Polygon Amoy wallet
PRIVATE_KEY=your_private_key_here

# Polygon Amoy RPC (default works without key)
AMOY_RPC=https://rpc-amoy.polygon.technology/

# PolygonScan API key — get one free at https://polygonscan.com/myapikey
# Required for: npm run verify:amoy
POLYGONSCAN_API=your_polygonscan_api_key_here

# Bridge relayer (real mode)
CONTRACT_ADDRESS=0x8Abba481989476ea2C917337bCce07C2C48cd725

# Adresse ETH fallback utilisée par le bridge quand l'événement Fabric ne contient pas patientAddress.
# Requis si le chaincode medical_records.go est utilisé (n'émet pas encore patientEthAddress).
# En production, mettre à jour le chaincode pour inclure l'adresse ETH dans PrescriptionIssued.
BRIDGE_DEFAULT_PATIENT_ADDRESS=
