{
  "name": "medichain-bridge",
  "version": "0.1.0",
  "description": "Fabric ↔ Polygon relayer for MediChain+. Listens to Fabric chaincode events and forwards to the MediChainInsurance smart contract on Polygon Amoy.",
  "main": "relayer.js",
  "type": "module",
  "scripts": {
    "start": "node relayer.js --mode=real",
    "mock": "node relayer.js --mode=mock",
    "once": "node relayer.js --mode=mock --once"
  },
  "bin": {
    "medichain-bridge": "./relayer.js"
  },
  "dependencies": {
    "ethers": "^6.13.2"
  },
  "optionalDependencies": {
    "fabric-network": "^2.2.20",
    "fabric-ca-client": "^2.2.20"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
